<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required since Android 11 (API 30) so PackageManager.queryIntentActivities
         can see other browsers. Without this our discovery returns just our own
         self-filtered entry. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".LinkOpenerApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.LinkOpener">

        <!-- Settings / launcher entry. Standard activity, normal theme. -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Picker activity. singleInstance so rapid-fire link clicks don't
             stack multiple pickers. Translucent theme so the picker reads
             as a dialog over whatever app the user came from.
             Two intent-filters because Android requires the BROWSABLE
             category for browser registration to be picked up by the
             Default Apps page. -->
        <activity
            android:name=".PickerActivity"
            android:exported="true"
            android:launchMode="singleInstance"
            android:theme="@style/Theme.LinkOpener.Translucent">
            <!-- Default browser entry: tapped link in any app. The
                 `intent:` scheme catches `intent://…#Intent;…;end` URIs
                 some apps construct as deep-link wrappers around an
                 underlying http(s) URL — we unwrap them in
                 PickerActivity.forwardIntent. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
                <data android:scheme="intent" />
            </intent-filter>
            <!-- Share-sheet entry: "Share to → Link Opener" from any app
                 that fires ACTION_SEND text/plain. PickerActivity pulls
                 the first http(s) URL out of EXTRA_TEXT; this is the
                 dominant way URLs flow on mobile (a tap often launches an
                 in-app web view, share-out goes through this filter). -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

    </application>

</manifest>
